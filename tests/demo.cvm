int factorial(int n) {
    int result = 1;
    while (1 < n) {
        result = result * n;
        n = n - 1;
    };
    return(result);
}

int main() {
    print(10);
    print(10 - 3);
    print(10 * 3);
    print(10 / 3);

    bool flag = true;
    if (flag == true) {
        print(1);
    } else {
        print(0);
    };

    let x = 1;
    while (x < 6) {
        print(x);
        x = x + 1;
    };

    print(factorial(5));

    print(input());

    return(0);
}